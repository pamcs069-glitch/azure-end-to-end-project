{
  "name": "ds_bronze_payments_sink",
  "properties": {
    "linkedServiceName": {
      "referenceName": "ls_adls_bronze",
      "type": "LinkedServiceReference"
    },
    "parameters": {
      "p_ingestion_date": {
        "type": "string"
      },
      "p_page_number": {
        "type": "int"
      }
    },
    "type": "Json",
    "typeProperties": {
      "location": {
        "type": "AzureBlobFSLocation",
        "fileSystem": "bronze",
        "folderPath": {
          "value": "@concat('api/payments/raw/ingestion_date=', dataset().p_ingestion_date)",
          "type": "Expression"
        },
        "fileName": {
          "value": "@concat('page_', string(dataset().p_page_number), '.json')",
          "type": "Expression"
        }
      }
    }
  }
}
